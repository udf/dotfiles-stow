    "workbench.colorCustomizations": {
        "[Arc Dark Theme]": {
            "editor.findMatchHighlightBackground": "#70f8ff2a",
            "editor.lineHighlightBackground": "#1f242d",
            "editor.lineHighlightBorder": "#232933",
            "editorBracketMatch.background": "#ffffff40",
            "editorIndentGuide.activeBackground": "#666"
        }
    },
    "workbench.editor.empty.hint": "hidden",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.editor.navigationScope": "editorGroup",
    "workbench.editor.showTabs": "multiple",
    "workbench.editorAssociations": {
        "*.bin": "hexEditor.hexedit",
        "git-rebase-todo": "default"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "xml.java.home": "/usr/lib/jvm/default-runtime/"
}