    "chat.disableAIFeatures": false,
    "chat.tools.terminal.terminalProfile.linux": {
        "args": [
            "zsh"
        ],
        "color": "terminal.ansiBlue",
        "path": "wrap-rw-cwd"
    },
    "chat.viewSessions.orientation": "stacked",
    "dance.modes": {
        "normal": {
            "cursorStyle": "block",
            "selectionBehavior": "character"
        }
    },
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.maxComputationTime": 0,
    "editor.fontFamily": "'Hack Nerd Font Mono', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
    "editor.formatOnSave": false,
    "editor.inlineSuggest.enabled": false,
    "editor.largeFileOptimizations": false,
    "editor.renderControlCharacters": true,
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        80,
        100
    ],
    "editor.stickyScroll.enabled": false,
    "editor.suggestSelection": "first",
    "editor.tabSize": 2,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "git.confirmSync": false,
    "github.copilot.advanced": {
        "authProvider": "github"
    },
    "github.copilot.editor.enableAutoCompletions": false,
    "gitlens.codeLens.authors.enabled": false,
    "gitlens.codeLens.recentChange.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "branches": true,
        "commits": true,
        "contributors": true,
        "fileHistory": true,
        "launchpad": false,
        "remotes": true,
        "repositories": true,
        "searchAndCompare": false,
        "stashes": true,
        "tags": true,
        "worktrees": true
    },
    "http.proxySupport": "off",
    "inlineChat.lineNaturalLanguageHint": false,
    "isort.args": [
        "--profile",
        "black",
        "--indent",
        "2",
        "--lai",
        "2",
        "--multi-line",
        "VERTICAL_GRID_GROUPED"
    ],
    "java.configuration.checkProjectSettingsExclusions": false,
    "java.configuration.runtimes": [
        {
            "default": true,
            "name": "JavaSE-11",
            "path": "/usr/lib/jvm/java-11-openjdk/"
        }
    ],
    "java.semanticHighlighting.enabled": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "nix.enableLanguageServer": true,
    "nix.serverPath": "/home/sam/.nix-profile/bin/nil",
    "nix.serverSettings": {
        "nil": {
            "diagnostics": {
                "ignored": [
                    "unused_binding",
                    "unused_with"
                ]
            },
            "formatting": {
                "command": [
                    "nixfmt"
                ]
            }
        }
    },
    "python.createEnvironment.trigger": "off",
    "python.showStartPage": false,
    "redhat.telemetry.enabled": false,
    "security.workspace.trust.enabled": false,
    "spellright.configurationScope": "user",
    "spellright.documentTypes": [
        "markdown",
        "latex",
        "git-commit",
        "plaintext",
        "shellscript",
        "jsonc"
    ],
    "spellright.language": [
        "en_GB"
    ],
    "terminal.integrated.inheritEnv": false,
    "terminal.integrated.initialHint": false,
    "terminal.integrated.profiles.linux": {
        "zsh-rw-cwd": {
            "args": [
                "zsh"
            ],
            "color": "terminal.ansiBlue",
            "path": "wrap-rw-cwd"
        }
    },
    "terminal.integrated.stickyScroll.enabled": false,
    "thunder-client.followRedirects": false,
