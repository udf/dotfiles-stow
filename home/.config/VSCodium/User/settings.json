{
    "Lua.format.defaultConfig": {
        "max_line_length": "160"
    },
    "[c]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[csharp]": {
        "editor.defaultFormatter": "Leopotam.csharpfixformat"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[python]": {
        "editor.wordBasedSuggestions": "off",
        "gitlens.codeLens.symbolScopes": [
            "!Module"
        ]
    },
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "autoDocstring.docstringFormat": "sphinx",
    "basedpyright.analysis.diagnosticSeverityOverrides": {
        "reportUnknownArgumentType": "none",
        "reportUnknownLambdaType": "none",
        "reportUnknownMemberType": "none",
        "reportUnknownVariableType": "none"
    },
    "cSpell.enabledFileTypes": {
        "nix": false
    },
    "cSpell.language": "en-GB",
    "cSpell.userWords": [
        "asyncio",
        "botapi",
        "centered",
        "centering",
        "craftable",
        "deepcopy",
        "desync",
        "Dialog",
        "elem",
        "flib",
        "fluidbox",
        "fluidboxes",
        "HMAC",
        "mt",
        "mult",
        "Playerctl",
        "proto",
        "redux",
        "romaji",
        "struct",
        "Syncthing",
        "upvote",
        "vals"
    ],
    "chat.disableAIFeatures": false,
    "chat.tools.terminal.terminalProfile.linux": {
        "args": [
            "zsh"
        ],
        "color": "terminal.ansiBlue",
        "path": "wrap-rw-cwd"
    },
    "chat.viewSessions.orientation": "stacked",
    "dance.modes": {
        "normal": {
            "cursorStyle": "block",
            "selectionBehavior": "character"
        }
    },
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.maxComputationTime": 0,
    "editor.fontFamily": "'Hack Nerd Font Mono', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "editor.largeFileOptimizations": false,
    "editor.renderControlCharacters": true,
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        80,
        100
    ],
    "editor.stickyScroll.enabled": false,
    "editor.suggestSelection": "first",
    "editor.tabSize": 2,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "git.confirmSync": false,
    "gitlens.codeLens.authors.enabled": false,
    "gitlens.codeLens.recentChange.enabled": false,
    "gitlens.launchpad.indicator.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "branches": true,
        "commits": true,
        "contributors": true,
        "fileHistory": true,
        "launchpad": false,
        "remotes": true,
        "repositories": true,
        "searchAndCompare": false,
        "stashes": true,
        "tags": true,
        "worktrees": true
    },
    "http.proxySupport": "off",
    "isort.args": [
        "--profile",
        "black",
        "--indent",
        "2",
        "--lai",
        "2",
        "--multi-line",
        "VERTICAL_GRID_GROUPED"
    ],
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nixd",
    "nix.serverSettings": {
        "nixd": {
            "formatting": {
                "command": [
                    "nixfmt"
                ]
            },
            "options": {
                "home-manager": {
                    "expr": "(builtins.getFlake \"/home/sam/proj/p/nix-configs\").nixosConfigurations.riko.options.home-manager.users.type.getSubOptions []"
                }
            }
        }
    },
    "redhat.telemetry.enabled": false,
    "security.workspace.trust.enabled": false,
    "terminal.integrated.inheritEnv": false,
    "terminal.integrated.initialHint": false,
    "terminal.integrated.profiles.linux": {
        "zsh-rw-cwd": {
            "args": [
                "zsh"
            ],
            "color": "terminal.ansiBlue",
            "path": "wrap-rw-cwd"
        }
    },
    "terminal.integrated.stickyScroll.enabled": false,
    "workbench.editor.empty.hint": "hidden",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.editor.navigationScope": "editorGroup",
    "workbench.editor.showTabs": "multiple",
    "workbench.editorAssociations": {
        "*.bin": "hexEditor.hexedit",
        "git-rebase-todo": "default"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.secondarySideBar.defaultVisibility": "hidden"
}