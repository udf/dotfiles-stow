{
    "C_Cpp.clang_format_style": "{BasedOnStyle: LLVM, IndentWidth: 4, SpaceAfterTemplateKeyword: false, AlwaysBreakTemplateDeclarations: true, BinPackArguments: false, BinPackParameters: false, AllowAllParametersOfDeclarationOnNextLine: false, AllowShortFunctionsOnASingleLine: false, BreakBeforeBinaryOperators: \"NonAssignment\", AlignAfterOpenBracket: \"AlwaysBreak\"}",
    "C_Cpp.default.includePath": [
        "/usr/include/opencv4"
    ],
    "C_Cpp.updateChannel": "Insiders",
    "Lua.format.defaultConfig": {
        "max_line_length": "160"
    },
    "[c]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[csharp]": {
        "editor.defaultFormatter": "Leopotam.csharpfixformat"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[python]": {
        "editor.wordBasedSuggestions": "off",
        "gitlens.codeLens.symbolScopes": [
            "!Module"
        ]
    },
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "autoDocstring.docstringFormat": "sphinx",
    "basedpyright.analysis.diagnosticSeverityOverrides": {
        "reportUnknownArgumentType": "none",
        "reportUnknownLambdaType": "none",
        "reportUnknownMemberType": "none",
        "reportUnknownVariableType": "none"
    },
    "cSpell.enableFiletypes": [
        "lua"
    ],
    "cSpell.enabled": true,
    "cSpell.language": "en-GB",
    "cSpell.userWords": [
        "asyncio",
        "botapi",
        "centered",
        "centering",
        "craftable",
        "deepcopy",
        "desync",
        "Dialog",
        "elem",
        "flib",
