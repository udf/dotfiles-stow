{
    "Lua.format.defaultConfig": {
        "max_line_length": "160"
    },
    "[c]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[csharp]": {
        "editor.defaultFormatter": "Leopotam.csharpfixformat"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[python]": {
        "editor.defaultFormatter": "eeyore.yapf",
        "editor.formatOnType": false
    },
    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "autoDocstring.docstringFormat": "sphinx",
    "basedpyright.analysis.diagnosticSeverityOverrides": {
        "reportUnknownArgumentType": "none",
        "reportUnknownLambdaType": "none",
        "reportUnknownMemberType": "none",
        "reportUnknownVariableType": "none"
    },
    "cSpell.enabledFileTypes": {
        "nix": false
    },
    "cSpell.language": "en-GB",
    "cSpell.userWords": [
        "asyncio",
        "botapi",
        "centered",
        "centering",
        "cooldown",
        "craftable",
        "deepcopy",
        "desync",
        "Dialog",
        "elem",
        "flib",
        "fluidbox",
        "fluidboxes",
        "HMAC",
        "mt",
        "mult",
        "Playerctl",
        "proto",
        "redux",
        "romaji",
        "struct",
        "Syncthing",
        "upvote",
        "vals"
    ],
    "chat.disableAIFeatures": false,
    "chat.tools.terminal.terminalProfile.linux": {
        "args": [
            "zsh"
        ],
        "color": "terminal.ansiBlue",
        "path": "wrap-rw-cwd"
    },
    "chat.viewSessions.orientation": "stacked",
    "cucumber.glue": [
        "packages/e2e/src/step-definitions/**/*.ts",
        "apps/*/cypress/**/*.ts"
    ],
    "dance.modes": {
        "normal": {
            "cursorStyle": "block",
            "selectionBehavior": "character"
        }
    },
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.maxComputationTime": 0,
    "editor.fontFamily": "'Hack Nerd Font Mono', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "editor.largeFileOptimizations": false,
    "editor.renderControlCharacters": true,
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        80,
        100
    ],
    "editor.stickyScroll.enabled": false,
    "editor.showDeprecated": false,
    "editor.suggestSelection": "first",
    "editor.tabSize": 2,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.wordWrap": "on",
    "explorer.confirmDragAndDrop": false,
    "files.insertFinalNewline": true,
    "git.blame.editorDecoration.enabled": false,
    "git.blame.statusBarItem.enabled": true,
    "git.confirmSync": false,
    "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
    "github.copilot.chat.alternateGptPrompt.enabled": true,
    "github.copilot.enable": {
        "*": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "gitlens.codeLens.authors.enabled": false,
    "gitlens.codeLens.recentChange.enabled": false,
    "gitlens.launchpad.indicator.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "branches": true,
        "commits": true,
        "contributors": true,
        "fileHistory": true,
        "launchpad": false,
        "remotes": true,
        "repositories": true,
        "searchAndCompare": false,
        "stashes": true,
        "tags": true,
        "worktrees": true
    },
    "inlineChat.lineNaturalLanguageHint": false,
    "isort.args": [
        "--profile",
        "black",
        "--indent",
        "2",
        "--lai",
        "2",
        "--multi-line",
        "VERTICAL_GRID_GROUPED"
    ],
    "js.updateImportsOnFileMove.enabled": "always",
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nixd",
    "nix.serverSettings": {
        "nixd": {
            "formatting": {
                "command": [
                    "nixfmt"
                ]
            },
            "nixpkgs": {
                "expr": "import (builtins.getFlake \"/home/sam/proj/p/nix-configs\").inputs.nixpkgs-unstable { }"
            },
            "options": {
                "home-manager": {
                    "expr": "(builtins.getFlake \"/home/sam/proj/p/nix-configs\").nixosConfigurations.riko.options.home-manager.users.type.getSubOptions []"
                },
                "nixos": {
                    "expr": "(builtins.getFlake \"/home/sam/proj/p/nix-configs\").nixosConfigurations.riko.options"
                }
            }
        }
    },
    "redhat.telemetry.enabled": false,
    "security.workspace.trust.enabled": false,
    "tailwindCSS.classAttributes": [
        "class",
        "className",
        "ngClass",
        "class:list",
        ".*ClassName"
    ],
    "tailwindCSS.experimental.classRegex": [
        [
            "cn\\(([^)]*)\\)",
            "[\"'`]([^\"'`]*)[\"'`]"
        ]
    ],
    "terminal.integrated.confirmOnKill": "always",
    "terminal.integrated.enableVisualBell": true,
    "terminal.integrated.initialHint": false,
    "terminal.integrated.profiles.linux": {
        "zsh-rw-cwd": {
            "args": [
                "zsh"
            ],
            "color": "terminal.ansiBlue",
            "path": "wrap-rw-cwd"
        }
    },
    "terminal.integrated.stickyScroll.enabled": false,
    "terminal.integrated.suggest.cdPath": "off",
    "terminal.integrated.suggest.enabled": false,
    "terminal.integrated.suggest.inlineSuggestion": "off",
    "ts.updateImportsOnFileMove.enabled": "always",
    "window.zoomLevel": -0.5,
    "workbench.editor.empty.hint": "hidden",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "workbench.editor.navigationScope": "editorGroup",
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.editor.showTabs": "multiple",
    "workbench.editorAssociations": {
        "*.bin": "hexEditor.hexedit"
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "yapf.args": [
        "--style",
        "{based_on_style: pep8, column_limit: 100, INDENT_WIDTH: 2, CONTINUATION_INDENT_WIDTH: 2, DEDENT_CLOSING_BRACKETS: true, COALESCE_BRACKETS: true, ALLOW_SPLIT_BEFORE_DICT_VALUE: false, BLANK_LINES_BEFORE_NESTED_CLASS_OR_DEF: false}"
    ],
    "chat.tips.enabled": false,
    "continue.showInlineTip": false,
    "workbench.colorTheme": "Dark Modern",
    "js/ts.preferGoToSourceDefinition": true,
    "js/ts.tsserver.maxMemory": 4096,
    "js/ts.updateImportsOnFileMove.enabled": "always",
    "[markdown]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
}
